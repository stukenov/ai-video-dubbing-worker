<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/index.css">
</head>
<body>
    <div class="container">
        <h1><%= title %></h1>
        <p><%= message %></p>
        
        <div class="upload-section">
            <h2>Загрузите видео и выберите язык для дубляжа</h2>
            
            <form id="uploadForm" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="videoFile" class="file-label">
                        <span class="file-label-text">Выберите видео файл</span>
                        <input type="file" id="videoFile" name="video" accept="video/*" required>
                    </label>
                    <div class="file-name" id="fileName"></div>
                </div>
                
                <div class="form-group">
                    <label for="language">Выберите язык для дубляжа:</label>
                    <select id="language" name="language" required>
                        <option value="">-- Выберите язык --</option>
                        <option value="ru">Русский</option>
                        <option value="en">English</option>
                        <option value="es">Español</option>
                        <option value="fr">Français</option>
                        <option value="de">Deutsch</option>
                        <option value="it">Italiano</option>
                        <option value="pt">Português</option>
                        <option value="ja">日本語</option>
                        <option value="ko">한국어</option>
                        <option value="zh">中文</option>
                    </select>
                </div>
                
                <div class="progress-container" id="progressContainer" style="display: none;">
                    <div class="progress-bar">
                        <div class="progress-fill" id="progressFill"></div>
                    </div>
                    <div class="progress-text" id="progressText">0%</div>
                </div>
                
                <button type="submit" class="btn" id="submitBtn">Начать дубляж</button>
            </form>
        </div>
        
        <% if (recentVideos && recentVideos.length > 0) { %>
            <div class="videos-section">
                <h2>Последние загруженные видео</h2>
                <div class="videos-list">
                    <% recentVideos.forEach(function(video) { %>
                        <a href="/video/<%= video.filename %>" class="video-item-link">
                            <div class="video-item">
                                <div class="video-info">
                                    <div class="video-name"><%= video.originalName %></div>
                                    <div class="video-meta">
                                        <span class="video-language">Язык: <%= video.languageName || video.language %></span>
                                        <span class="video-date"><%= new Date(video.uploadedAt).toLocaleString('ru-RU') %></span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    <% }); %>
                </div>
            </div>
        <% } %>
        
        <div class="actions">
            <form method="POST" action="/logout">
                <button type="submit" class="btn btn-secondary">Выйти</button>
            </form>
        </div>
    </div>

    <script>
        const uploadForm = document.getElementById('uploadForm');
        const videoFileInput = document.getElementById('videoFile');
        const fileName = document.getElementById('fileName');
        const progressContainer = document.getElementById('progressContainer');
        const progressFill = document.getElementById('progressFill');
        const progressText = document.getElementById('progressText');
        const submitBtn = document.getElementById('submitBtn');

        // Показывать имя выбранного файла
        videoFileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                fileName.textContent = e.target.files[0].name;
                fileName.style.display = 'block';
            } else {
                fileName.style.display = 'none';
            }
        });

        // Обработка отправки формы
        uploadForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(uploadForm);
            const file = videoFileInput.files[0];
            const language = document.getElementById('language').value;
            
            if (!file) {
                alert('Пожалуйста, выберите видео файл');
                return;
            }
            
            if (!language) {
                alert('Пожалуйста, выберите язык для дубляжа');
                return;
            }
            
            // Показываем прогрессбар
            progressContainer.style.display = 'block';
            submitBtn.disabled = true;
            submitBtn.textContent = 'Загрузка...';
            
            // Создаем XMLHttpRequest для отслеживания прогресса
            const xhr = new XMLHttpRequest();
            
            // Отслеживание прогресса загрузки
            xhr.upload.addEventListener('progress', (e) => {
                if (e.lengthComputable) {
                    const percentComplete = (e.loaded / e.total) * 100;
                    progressFill.style.width = percentComplete + '%';
                    progressText.textContent = Math.round(percentComplete) + '%';
                }
            });
            
            // Обработка завершения загрузки
            xhr.addEventListener('load', () => {
                if (xhr.status === 200) {
                    try {
                        const response = JSON.parse(xhr.responseText);
                        if (response.success) {
                            progressFill.style.width = '100%';
                            progressText.textContent = '100%';
                            setTimeout(() => {
                                alert('Видео успешно загружено!');
                                uploadForm.reset();
                                fileName.style.display = 'none';
                                progressContainer.style.display = 'none';
                                submitBtn.disabled = false;
                                submitBtn.textContent = 'Начать дубляж';
                                // Перезагружаем страницу для обновления списка видео
                                window.location.reload();
                            }, 500);
                        } else {
                            alert(response.error || 'Ошибка при загрузке видео');
                            progressContainer.style.display = 'none';
                            submitBtn.disabled = false;
                            submitBtn.textContent = 'Начать дубляж';
                        }
                    } catch (e) {
                        alert('Ошибка при обработке ответа сервера');
                        progressContainer.style.display = 'none';
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'Начать дубляж';
                    }
                } else {
                    try {
                        const response = JSON.parse(xhr.responseText);
                        alert(response.error || 'Ошибка при загрузке видео');
                    } catch (e) {
                        alert('Ошибка при загрузке видео');
                    }
                    progressContainer.style.display = 'none';
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Начать дубляж';
                }
            });
            
            // Обработка ошибок
            xhr.addEventListener('error', () => {
                alert('Ошибка соединения с сервером');
                progressContainer.style.display = 'none';
                submitBtn.disabled = false;
                submitBtn.textContent = 'Начать дубляж';
            });
            
            // Отправка запроса
            xhr.open('POST', '/upload');
            xhr.send(formData);
        });
    </script>
</body>
</html>

